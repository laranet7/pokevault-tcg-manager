POKEMON_TCG_API_KEY=
MEDIA_ROOT=./media
SEED_DEFAULT_ADMIN=true
TERMS_VERSION=1.0
AUTH_SECRET_KEY=change-me-with-a-long-random-secret
AUTH_TOKEN_TTL_HOURS=24

VITE_API_BASE_URL=http://localhost:8000/api
