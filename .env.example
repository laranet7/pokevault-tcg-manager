POSTGRES_USER=pokevault
POSTGRES_PASSWORD=pokevault
POSTGRES_DB=pokevault
POSTGRES_PORT=5433

DATABASE_URL=postgresql+asyncpg://pokevault:pokevault@db:5432/pokevault
CORS_ORIGINS=http://localhost:8080
